# Impressum-Scraper — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage deine Keys ein.

# Serper API Key (primärer Such-Provider)
# Kostenlosen Key holen: https://serper.dev  (2500 Suchen/Monat gratis)
SERPER_API_KEY=dein-key-von-serper.dev

# Gemini API Key (optional, für zukünftige KI-gestützte Extraktion)
GEMINI_API_KEY=dein-gemini-api-key
