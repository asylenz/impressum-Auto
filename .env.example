# LinkedIn Credentials
LINKEDIN_EMAIL=deine-email@example.com
LINKEDIN_PASSWORD=dein-passwort

# Google Sheets
SHEET_ID=deine-google-sheet-id

# Serper API für Google-Suche (https://serper.dev)
SERPER_API_KEY=dein-api-key-hier

# Lusha API für Telefonnummer- und Stufen-Fallback (https://dashboard.lusha.com/enrich/api)
LUSHA_API_KEY=dein-lusha-api-key-hier

# Limits (Optional - Defaults in config.yaml)
# LINKEDIN_MAX_PROFILES_PER_DAY=50
# LINKEDIN_MAX_PROFILES_PER_HOUR=25
# XING_MAX_PROFILES_PER_HOUR=30

# Debug-Modus (headed browser für Debugging)
# DEBUG_MODE=false
